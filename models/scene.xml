<mujoco model="load_transport_scene">
    <compiler angle="degree" coordinate="local"/>
    <option timestep="0.002" gravity="0 0 -9.81"/>

    <include file="mobile_base_payload.xml"/>

    <asset>
        <texture name="grid" type="2d" builtin="checker"
                 width="512" height="512"
                 rgb1="0.62 0.72 0.82"
                 rgb2="0.48 0.60 0.72"/>

        <material name="grid_mat"
                  texture="grid"
                  texrepeat="32 32"
                  reflectance="0.01"/>

        <texture name="skybox" type="skybox" builtin="gradient"
                 rgb1="0.90 0.94 0.98"
                 rgb2="0.58 0.70 0.82"
                 width="512" height="512"/>
    </asset>

    <worldbody>
        <geom name="floor"
              type="plane"
              size="20 20 0.1"
              material="grid_mat"/>

        <light pos="0 0 5"
               dir="0 0 -1"
               diffuse="0.65 0.65 0.65"
               specular="0.05 0.05 0.05"/>

        <light pos="-3 -3 4"
               dir="1 1 -1"
               diffuse="0.25 0.25 0.25"
               specular="0 0 0"/>

        <camera name="main_cam"
                pos="2.5 -2.5 2.0"
                xyaxes="0.7 0.7 0  -0.4 0.4 0.8"/>
    </worldbody>
</mujoco>